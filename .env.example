# InvestorOS / Review Hub environment
# Copy to .env.local for local development and set these in Netlify for deployment.
# Do not commit real secrets.

# Public browser Supabase client values.
# These are safe to expose in the browser when RLS is correctly configured.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key

# Server-side Supabase values used by TanStack Start server functions.
# SUPABASE_SERVICE_ROLE_KEY must be configured only in Netlify/server runtime.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# Optional AI concierge provider key. App falls back to a grounded static answer if unset.
GEMINI_API_KEY=

# Optional future model override if src/lib/investor-room.functions.ts is updated to read it.
GEMINI_MODEL=gemini-2.5-flash

# Optional company metadata for future adapters.
VITE_COMPANY_NAME=Mport Media Technologies, Inc.
VITE_PRODUCT_NAME=Discharge Bridge

# Netlify build reference
# Build command: npm run build
# Publish directory: .output/public
